#!/usr/bin/env bash
# Auto-generated by llmoji $LLMOJI_VERSION. DO NOT edit by hand —
# `llmoji install hermes` regenerates this file from
# llmoji/_hooks/hermes.sh.tmpl. Edits will be lost.
#
# Hermes post_llm_call hook: read-only journal logger. NEVER blocks.
# Appends one JSONL row per assistant turn to the configured
# journal in the canonical 6-field schema:
#
#   ts             ISO-8601 UTC  hook fire time
#   model          str           extra.model
#   cwd            str           working directory at hook fire
#   kaomoji        str           leading non-letter prefix of the
#                                final assistant_response, ≥2 bytes
#   user_text      str           extra.user_message (pre-injection)
#   assistant_text str           extra.assistant_response MINUS the
#                                leading kaomoji + surrounding
#                                whitespace
#
# Sidechain handling: a companion subagent_stop hook (installed
# alongside this one) writes child session_ids to
# ~/.hermes/.llmoji-children. We drop matching session_ids here so
# subagent turns don't pollute the journal.
#
# Hermes hook return contract: stdout JSON, {} is no-op, fail-open.
#
# Consumed by `llmoji analyze` via llmoji.sources.journal.
set -u

INPUT=$(cat)

# Hermes payload shape (post_llm_call): all six llmoji fields land
# in one event under the .extra dict.
ASSISTANT_TEXT=$(printf '%s' "$INPUT" | jq -r '.extra.assistant_response // empty' 2>/dev/null || printf '')
[ -z "$ASSISTANT_TEXT" ] && { echo '{}'; exit 0; }

USER_TEXT=$(printf '%s' "$INPUT"  | jq -r '.extra.user_message     // empty' 2>/dev/null || printf '')
MODEL=$(printf '%s' "$INPUT"      | jq -r '.extra.model            // empty' 2>/dev/null || printf '')
CWD=$(printf '%s' "$INPUT"        | jq -r '.cwd                    // empty' 2>/dev/null || printf '')
SESSION_ID=$(printf '%s' "$INPUT" | jq -r '.session_id             // empty' 2>/dev/null || printf '')

# Sidechain filter: post_llm_call fires for both parent and
# subagent (delegate_task) sessions. The companion subagent_stop
# hook writes child session_ids here as plain text, one per line.
# Drop matches.
CHILD_STATE="${HOME}/.hermes/.llmoji-children"
if [ -n "$SESSION_ID" ] && [ -f "$CHILD_STATE" ]; then
  if grep -qFx "$SESSION_ID" "$CHILD_STATE" 2>/dev/null; then
    echo '{}'
    exit 0
  fi
fi

${KAOMOJI_VALIDATE}

${JOURNAL_WRITE}

echo '{}'
exit 0

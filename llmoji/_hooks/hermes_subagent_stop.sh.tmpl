#!/usr/bin/env bash
# Auto-generated by llmoji $LLMOJI_VERSION. DO NOT edit by hand —
# `llmoji install hermes` regenerates this file from
# llmoji/_hooks/hermes_subagent_stop.sh.tmpl. Edits will be lost.
#
# Hermes subagent_stop companion: appends the just-finished
# subagent's session_id to a state file the post_llm_call hook
# consults. Together this is the session-correlation sidechain
# strategy:
#
#   1. delegate_task fires when the agent dispatches a subagent.
#   2. ...subagent runs, possibly emitting its own post_llm_call.
#      We don't try to filter at delegate-time because the child's
#      session_id may not be in the parent payload until the
#      child has actually run.
#   3. subagent_stop fires when the child's session ends — its
#      payload's `session_id` IS the child's id, with
#      `extra.parent_session_id` pointing at the parent. We log
#      the child id here.
#   4. post_llm_call sees a session_id that's now in the state
#      file and skips the journal write.
#
# Stdin payload shape (per docs):
#   {
#     "hook_event_name": "subagent_stop",
#     "session_id": "<child id>",
#     "extra": {
#       "parent_session_id": "...",
#       "child_role":        "...",
#       "child_status":      "..."
#     }
#   }
#
# Stdout: JSON. {} is no-op, fail-open.
set -u

INPUT=$(cat)

CHILD_ID=$(printf '%s' "$INPUT" | jq -r '.session_id // empty' 2>/dev/null || printf '')
[ -z "$CHILD_ID" ] && { echo '{}'; exit 0; }

CHILD_STATE="$CHILD_STATE_PATH"
mkdir -p "$(dirname "$CHILD_STATE")"

# Append iff not already present. `grep -qFx` matches the literal
# id as a full line; the append uses the same form.
if ! grep -qFx "$CHILD_ID" "$CHILD_STATE" 2>/dev/null; then
  printf '%s\n' "$CHILD_ID" >> "$CHILD_STATE" 2>/dev/null || true
fi

echo '{}'
exit 0

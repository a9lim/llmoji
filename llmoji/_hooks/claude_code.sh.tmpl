#!/usr/bin/env bash
# Auto-generated by llmoji $LLMOJI_VERSION. DO NOT edit by hand —
# `llmoji install claude_code` regenerates this file from
# llmoji/_hooks/claude_code.sh.tmpl. Edits will be lost.
#
# Stop hook: read-only journal logger. NEVER blocks.
# Appends one JSONL row per assistant turn to the configured
# journal in the canonical 6-field schema:
#
#   ts             ISO-8601 UTC  hook fire time
#   model          str           active model slug
#   cwd            str           working directory
#   kaomoji        str           leading non-letter prefix of last
#                                assistant message, ≥2 bytes; rows
#                                without one are skipped (no write)
#   user_text      str           latest real user turn
#   assistant_text str           last assistant text MINUS the
#                                leading kaomoji + surrounding
#                                whitespace
#
# Consumed by `llmoji analyze` via llmoji.sources.journal.
set -u

INPUT=$(cat)

TRANSCRIPT=$(printf '%s' "$INPUT" | jq -r '.transcript_path // empty' 2>/dev/null || true)
CWD=$(printf '%s' "$INPUT"         | jq -r '.cwd             // empty' 2>/dev/null || true)

[ -z "$TRANSCRIPT" ] && exit 0
[ ! -f "$TRANSCRIPT" ] && exit 0

# Skip sidechain (subagent) turns — agent-to-agent dispatches are
# not human-driven and shouldn't mix with the kaomoji-vs-human-prompt
# corpus. `isSidechain` is set on every event in a Task-spawned
# session.
IS_SIDECHAIN=$(jq -rs '
  map(select(.type == "assistant")) | last | (.isSidechain // false)
' "$TRANSCRIPT" 2>/dev/null || printf 'false')
[ "$IS_SIDECHAIN" = "true" ] && exit 0

# Claude Code persists every assistant content block — text,
# tool_use, thinking — as its OWN top-level entry in the transcript
# JSONL. A single turn produces many assistant entries; the
# kaomoji-led text may sit at any position (pre-tool, post-tool, or
# sandwiched). Naive `last(assistant)` only catches turns that
# finish with text and never resume — every text-then-more-tools
# turn was getting silently dropped.
#
# Fix: scope to the current turn (the events at-or-after the latest
# real-user prompt — content-string or text-block, NOT tool_result)
# and pick the FIRST text-bearing assistant entry. The
# UserPromptSubmit nudge drives the model to lead with the kaomoji,
# so the first text in the turn is the kaomoji-bearing reply.
BOUNDARY_TS=$(jq -rs '
  map(select(
    .type == "user"
    and (
      (.message.content | type) == "string"
      or (
        (.message.content | type) == "array"
        and ((.message.content | any(.type == "tool_result")) | not)
      )
    )
  ))
  | last
  | (.timestamp // "")
' "$TRANSCRIPT" 2>/dev/null || printf '')

# Reading the transcript twice is wasteful but jq's slurp is cheap
# (transcripts are tens of KB to a few MB) and isolating each query
# keeps the script easy to debug.
MODEL=$(jq -rs --arg b "$BOUNDARY_TS" '
  map(select(
    .type == "assistant"
    and ((.timestamp // "") >= $b)
    and ((.isSidechain // false) | not)
    and ((.message.content // []) | any(.type == "text" and ((.text // "") | length > 0)))
  ))
  | (.[0] // {})
  | (.message.model // "")
' "$TRANSCRIPT" 2>/dev/null || printf '')

ASSISTANT_TEXT=$(jq -rs --arg b "$BOUNDARY_TS" '
  map(select(
    .type == "assistant"
    and ((.timestamp // "") >= $b)
    and ((.isSidechain // false) | not)
    and ((.message.content // []) | any(.type == "text" and ((.text // "") | length > 0)))
  ))
  | (.[0] // {})
  | ((.message.content // []) | map(select(.type == "text")) | .[0].text // "")
' "$TRANSCRIPT" 2>/dev/null || printf '')

[ -z "$ASSISTANT_TEXT" ] && exit 0

# Latest real user turn. Walks every user event, builds a string
# per event (plain string content OR concatenated text blocks,
# ignoring tool_result), drops skill-injected payloads, keeps the
# last surviving non-empty one. Skill-injected prefix list comes
# from the package taxonomy + provider definition.
USER_TEXT=$(jq -rs '
  [ .[]
    | select(.type == "user")
    | .message.content as $c
    | if   ($c | type) == "string" then $c
      elif ($c | type) == "array"  then ($c | map(select(.type == "text") | .text // "") | join("\n"))
      else "" end
    | select(. != "" and ($INJECTED_PREFIXES_FILTER))
  ]
  | last // ""
' "$TRANSCRIPT" 2>/dev/null || printf '')

${KAOMOJI_VALIDATE}

${JOURNAL_WRITE}

exit 0

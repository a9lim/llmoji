#!/usr/bin/env bash
# Auto-generated by llmoji $LLMOJI_VERSION. DO NOT edit by hand —
# `llmoji install claude_code` regenerates this file from
# llmoji/_hooks/claude_code.sh.tmpl. Edits will be lost.
#
# Stop hook: read-only journal logger. NEVER blocks.
# Appends one JSONL row per assistant turn to the configured
# journal in the canonical 6-field schema:
#
#   ts             ISO-8601 UTC  hook fire time
#   model          str           active model slug
#   cwd            str           working directory
#   kaomoji        str           leading non-letter prefix of last
#                                assistant message, ≥2 bytes; rows
#                                without one are skipped (no write)
#   user_text      str           latest real user turn
#   assistant_text str           last assistant text MINUS the
#                                leading kaomoji + surrounding
#                                whitespace
#
# Consumed by `llmoji analyze` via llmoji.sources.journal.
set -u

INPUT=$(cat)

TRANSCRIPT=$(printf '%s' "$INPUT" | jq -r '.transcript_path // empty' 2>/dev/null || true)
CWD=$(printf '%s' "$INPUT"         | jq -r '.cwd             // empty' 2>/dev/null || true)

[ -z "$TRANSCRIPT" ] && exit 0
[ ! -f "$TRANSCRIPT" ] && exit 0

# Skip sidechain (subagent) turns — agent-to-agent dispatches are
# not human-driven and shouldn't mix with the kaomoji-vs-human-prompt
# corpus. `isSidechain` is set on every event in a Task-spawned
# session.
IS_SIDECHAIN=$(jq -rs '
  map(select(.type == "assistant")) | last | (.isSidechain // false)
' "$TRANSCRIPT" 2>/dev/null || printf 'false')
[ "$IS_SIDECHAIN" = "true" ] && exit 0

# Last assistant message: model + first text block. Reading the
# transcript twice is wasteful but jq's slurp is cheap (transcripts
# are tens of KB to a few MB) and isolating each query keeps the
# script easy to debug.
MODEL=$(jq -rs '
  map(select(.type == "assistant")) | last | (.message.model // "")
' "$TRANSCRIPT" 2>/dev/null || printf '')

# Claude Code assistant content is one event with interleaved
# `text + tool_use + text` content blocks. The kaomoji-prefixed
# reply is the FIRST text block; later text is post-tool
# continuation, irrelevant to kaomoji analysis.
ASSISTANT_TEXT=$(jq -rs '
  map(select(.type == "assistant"))
  | last
  | .message.content
  | (if type == "array" then (map(select(.type == "text")) | .[0].text // "") else (. // "") end)
' "$TRANSCRIPT" 2>/dev/null || printf '')

[ -z "$ASSISTANT_TEXT" ] && exit 0

# Latest real user turn. Walks every user event, builds a string
# per event (plain string content OR concatenated text blocks,
# ignoring tool_result), drops skill-injected payloads, keeps the
# last surviving non-empty one. Skill-injected prefix list comes
# from the package taxonomy + provider definition.
USER_TEXT=$(jq -rs '
  [ .[]
    | select(.type == "user")
    | .message.content as $c
    | if   ($c | type) == "string" then $c
      elif ($c | type) == "array"  then ($c | map(select(.type == "text") | .text // "") | join("\n"))
      else "" end
    | select(. != "" and ($INJECTED_PREFIXES_FILTER))
  ]
  | last // ""
' "$TRANSCRIPT" 2>/dev/null || printf '')

# Kaomoji prefix: first non-empty line, strip leading whitespace,
# drop everything from the first ASCII letter, trim trailing
# whitespace. ≥2 bytes filters lone "→"/"!"/etc. Skip the journal
# write entirely on prose-leading turns — null-kaomoji rows are
# noise.
FIRST_LINE=$(printf '%s' "$ASSISTANT_TEXT" | awk 'NF{print; exit}')
KAOMOJI=$(printf '%s' "$FIRST_LINE" \
  | sed -E 's/^[[:space:]]+//' \
  | sed -E 's/[A-Za-z].*$//' \
  | sed -E 's/[[:space:]]+$//')
if [ -z "$KAOMOJI" ] || [ "${#KAOMOJI}" -lt 2 ]; then
  exit 0
fi
# Match the project-wide KAOMOJI_START_CHARS set (see
# llmoji.taxonomy). Filters out markdown bullets, list dashes,
# ASCII headers, etc.
case "$KAOMOJI" in
  $KAOMOJI_START_CASE) ;;
  *) exit 0 ;;
esac
# Reject markdown-escape artifacts. A literal `\` in the kaomoji
# is always a model emitting `\*` (backslash-escape) inside what
# looks like a kaomoji bracket. Mirrored in
# llmoji.taxonomy.is_kaomoji_candidate.
case "$KAOMOJI" in
  *\\*) exit 0 ;;
esac
# Reject oversize spans: real kaomoji are ≤ ~30 chars. Without
# this, balanced-paren prose accidentally captured by the
# bracket-span scan could land in the journal. Mirrored in
# llmoji.taxonomy._KAOMOJI_MAX_LEN.
if [ "${#KAOMOJI}" -gt 32 ]; then
  exit 0
fi

JOURNAL="$JOURNAL_PATH"
mkdir -p "$(dirname "$JOURNAL")"

jq -nc \
  --arg ts             "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  --arg model          "$MODEL" \
  --arg cwd            "$CWD" \
  --arg kaomoji        "$KAOMOJI" \
  --arg user_text      "$USER_TEXT" \
  --arg assistant_text "$ASSISTANT_TEXT" \
  '{
    ts:             $ts,
    model:          $model,
    cwd:            $cwd,
    kaomoji:        $kaomoji,
    user_text:      $user_text,
    assistant_text: ($assistant_text
                     | sub("^\\s+"; "")
                     | ltrimstr($kaomoji)
                     | sub("^\\s+"; ""))
  }' \
  >> "$JOURNAL" 2>/dev/null || true

exit 0

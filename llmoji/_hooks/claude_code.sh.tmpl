#!/usr/bin/env bash
# Auto-generated by llmoji $LLMOJI_VERSION. DO NOT edit by hand —
# `llmoji install claude_code` regenerates this file from
# llmoji/_hooks/claude_code.sh.tmpl. Edits will be lost.
#
# Stop hook: read-only journal logger. NEVER blocks.
# Appends one JSONL row PER kaomoji-led assistant text entry in the
# current turn. Claude Code persists each assistant content block —
# text, tool_use, thinking — as its own top-level transcript JSONL
# entry, so a tool-heavy turn (text → tool_use → text → tool_use →
# text) emits up to one row per text block. The kaomoji filter
# decides which entries actually land in the journal; non-kaomoji
# entries are skipped without bailing the rest of the walk.
#
# Schema (canonical 6-field journal row):
#   ts             ISO-8601 UTC  hook fire time
#   model          str           active model slug
#   cwd            str           working directory
#   kaomoji        str           leading non-letter prefix of an
#                                assistant text entry, ≥2 bytes
#   user_text      str           latest real user turn (resolved
#                                once per turn — every row from
#                                this turn shares the same prompt)
#   assistant_text str           assistant text MINUS the leading
#                                kaomoji + surrounding whitespace
#
# Consumed by `llmoji analyze` via llmoji.sources.journal.
set -u

INPUT=$(cat)

TRANSCRIPT=$(printf '%s' "$INPUT" | jq -r '.transcript_path // empty' 2>/dev/null || true)
CWD=$(printf '%s' "$INPUT"         | jq -r '.cwd             // empty' 2>/dev/null || true)

[ -z "$TRANSCRIPT" ] && exit 0
[ ! -f "$TRANSCRIPT" ] && exit 0

# Skip sidechain (subagent) turns — agent-to-agent dispatches are
# not human-driven and shouldn't mix with the kaomoji-vs-human-prompt
# corpus. `isSidechain` is set on every event in a Task-spawned
# session.
IS_SIDECHAIN=$(jq -rs '
  map(select(.type == "assistant")) | last | (.isSidechain // false)
' "$TRANSCRIPT" 2>/dev/null || printf 'false')
[ "$IS_SIDECHAIN" = "true" ] && exit 0

# Boundary timestamp: latest real user turn. Real user = string content
# OR text-block array that's NOT a tool_result. Tool-result user events
# don't open a new conversational turn (they're machine-generated
# interleaving inside one). Every assistant entry at-or-after this
# timestamp is part of the current turn; we emit one row per kaomoji-
# led entry in that window.
BOUNDARY_TS=$(jq -rs '
  map(select(
    .type == "user"
    and (
      (.message.content | type) == "string"
      or (
        (.message.content | type) == "array"
        and ((.message.content | any(.type == "tool_result")) | not)
      )
    )
  ))
  | last
  | (.timestamp // "")
' "$TRANSCRIPT" 2>/dev/null || printf '')

# Latest real user turn resolution — same shape filter as the
# boundary query but flattened to the user_text we apply to every
# row from this turn. Skill-injected prefixes (the
# system_injected_prefixes list on the Provider class) are filtered
# defensively.
USER_TEXT=$(jq -rs '
  [ .[]
    | select(.type == "user")
    | .message.content as $c
    | if   ($c | type) == "string" then $c
      elif ($c | type) == "array"  then ($c | map(select(.type == "text") | .text // "") | join("\n"))
      else "" end
    | select(. != "" and ($INJECTED_PREFIXES_FILTER))
  ]
  | last // ""
' "$TRANSCRIPT" 2>/dev/null || printf '')

# Walk every text-bearing assistant entry in the current turn, emit
# one journal row per kaomoji-led entry. Each entry maps to ONE
# message the model wrote — Claude Code persists each content block
# as its own top-level transcript JSONL entry, so the natural
# granularity for capture is "one row per text-bearing entry that
# leads with a kaomoji."
#
# jq -c streams one JSON object per matching entry; we read those
# line-by-line in bash and run the validate + journal-write partials
# per iteration. The validate partial is rendered with
# ``SKIP_ACTION=continue`` so a non-kaomoji entry skips its row
# without aborting the rest of the walk.
jq -c --arg b "$BOUNDARY_TS" '
  select(
    .type == "assistant"
    and ((.timestamp // "") >= $b)
    and ((.isSidechain // false) | not)
    and ((.message.content // []) | any(.type == "text" and ((.text // "") | length > 0)))
  )
  | {
      text:  ((.message.content // []) | map(select(.type == "text")) | .[0].text // ""),
      model: (.message.model // "")
    }
' "$TRANSCRIPT" 2>/dev/null | while IFS= read -r row; do
  [ -z "$row" ] && continue
  ASSISTANT_TEXT=$(printf '%s' "$row" | jq -r '.text')
  MODEL=$(printf         '%s' "$row" | jq -r '.model')
  ${KAOMOJI_VALIDATE}
  ${JOURNAL_WRITE}
done

exit 0

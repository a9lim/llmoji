#!/usr/bin/env bash
# Auto-generated by llmoji $LLMOJI_VERSION. DO NOT edit by hand —
# `llmoji install codex` regenerates this file from
# llmoji/_hooks/codex.sh.tmpl. Edits will be lost.
#
# Codex Stop hook: read-only journal logger. NEVER blocks.
# Appends one JSONL row per assistant turn to the configured
# journal in the canonical 6-field schema:
#
#   ts             ISO-8601 UTC  hook fire time
#   model          str           active model slug
#   cwd            str           working directory
#   kaomoji        str           leading non-letter prefix of last
#                                assistant message, ≥2 bytes; rows
#                                without one are skipped (no write)
#   user_text      str           latest real user turn from rollout
#   assistant_text str           last assistant text MINUS the
#                                leading kaomoji + surrounding
#                                whitespace
#
# Consumed by `llmoji analyze` via llmoji.sources.journal.
set -u

INPUT=$(cat)

# Codex puts the kaomoji on the LAST agent message, not the first —
# the final summary lands on .last_assistant_message after the
# tool-calling loop completes. Per-message events fire repeatedly
# during a turn; we read this one stop-event field directly.
ASSISTANT_TEXT=$(printf '%s' "$INPUT" | jq -r '.last_assistant_message // empty' 2>/dev/null || printf '')
[ -z "$ASSISTANT_TEXT" ] && exit 0

MODEL=$(printf '%s' "$INPUT"   | jq -r '.model           // empty' 2>/dev/null || printf '')
CWD=$(printf '%s' "$INPUT"     | jq -r '.cwd             // empty' 2>/dev/null || printf '')
ROLLOUT=$(printf '%s' "$INPUT" | jq -r '.transcript_path // empty' 2>/dev/null || printf '')

# Latest real user turn. Codex injects AGENTS.md,
# <environment_context>, and bare <INSTRUCTIONS> blocks as
# user-role response_items at session start; the last user
# response_item in the rollout is the actual prompt by the time
# Stop fires. We still drop the synthetic prefixes defensively.
USER_TEXT=""
if [ -n "$ROLLOUT" ] && [ -f "$ROLLOUT" ]; then
  USER_TEXT=$(jq -rs '
    [ .[]
      | select(.type == "response_item" and (.payload.role // "") == "user")
      | (.payload.content
         | if type == "array"
           then (map(select(.type == "input_text") | .text // "") | join("\n"))
           else "" end)
      | select(. != "")
      | select($INJECTED_PREFIXES_FILTER)
    ]
    | last // ""
  ' "$ROLLOUT" 2>/dev/null || printf '')
fi

${KAOMOJI_VALIDATE}

${JOURNAL_WRITE}

exit 0

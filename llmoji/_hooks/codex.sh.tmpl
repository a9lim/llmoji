#!/usr/bin/env bash
# Auto-generated by llmoji $LLMOJI_VERSION. DO NOT edit by hand —
# `llmoji install codex` regenerates this file from
# llmoji/_hooks/codex.sh.tmpl. Edits will be lost.
#
# Codex Stop hook: read-only journal logger. NEVER blocks.
# Appends one JSONL row PER kaomoji-led agent_message in the current
# turn. A tool-heavy turn easily writes 5–10 ``event_msg.agent_message``
# events (each its own line in the rollout JSONL); any of them can
# be kaomoji-led, and the journal captures every kaomoji-led one,
# not just the final summary.
#
# Schema (canonical 6-field journal row):
#   ts             ISO-8601 UTC  hook fire time
#   model          str           active model slug (Stop event)
#   cwd            str           working directory (Stop event)
#   kaomoji        str           leading non-letter prefix of an
#                                agent_message, ≥2 bytes
#   user_text      str           latest real user turn (per-turn,
#                                resolved from the rollout)
#   assistant_text str           agent_message MINUS the leading
#                                kaomoji + surrounding whitespace
#
# Consumed by `llmoji analyze` via llmoji.sources.journal.
set -u

INPUT=$(cat)

MODEL=$(printf '%s' "$INPUT"   | jq -r '.model           // empty' 2>/dev/null || printf '')
CWD=$(printf '%s' "$INPUT"     | jq -r '.cwd             // empty' 2>/dev/null || printf '')
ROLLOUT=$(printf '%s' "$INPUT" | jq -r '.transcript_path // empty' 2>/dev/null || printf '')

[ -z "$ROLLOUT" ] && exit 0
[ ! -f "$ROLLOUT" ] && exit 0

# Single rollout read for the two turn-level facts we need:
#
#   * start_idx — index of the latest ``turn_context`` event. That
#     event fires once at the start of every turn; the last one is
#     for THIS turn (Stop fires after the turn's task_complete).
#     The per-message walk below slices forward from this index.
#     ``// 0`` falls back to the start of the file if there's no
#     turn_context (shouldn't happen in real rollouts, but keeps the
#     walk well-defined).
#   * user_text — latest real user response_item in the current
#     turn's slice. Codex injects AGENTS.md / <environment_context> /
#     <INSTRUCTIONS> as user-role response_items at session start
#     (BEFORE turn_context); slicing from turn_context already drops
#     them, but the prefix filter remains as defense-in-depth in case
#     Codex changes the placement.
#
# Pre-fix the hook ran two separate rollout slurps (one for
# start_idx, one for user_text) before the per-message walk did its
# own third read. One ``-cs`` call computes both inline; the small
# extractions below are cheap.
META=$(jq -cs '
  ([to_entries[] | select(.value.type == "turn_context") | .key] | last // 0) as $s
  | {
      start_idx: $s,
      user_text: (
        .[$s:]
        | [ .[]
            | select(.type == "response_item" and (.payload.role // "") == "user")
            | (.payload.content
               | if type == "array"
                 then (map(select(.type == "input_text") | .text // "") | join("\n"))
                 else "" end)
            | select(. != "")
            | select($INJECTED_PREFIXES_FILTER)
          ]
        | last // ""
      )
    }
' "$ROLLOUT" 2>/dev/null)
[ -z "$META" ] && META='{}'

START_IDX=$(printf '%s' "$META" | jq -r '.start_idx // 0')
USER_TEXT=$(printf '%s' "$META" | jq -r '.user_text // ""')

# Walk every event_msg.agent_message in the current turn and emit
# one journal row per kaomoji-led message. ``payload.message`` is
# the assistant text; ``payload.phase`` is ``"commentary"`` for
# progress messages and ``"final_answer"`` for the closing message,
# but we don't filter on phase — every kaomoji-led message counts.
#
# The validate partial is rendered with ``SKIP_ACTION=continue`` so
# a non-kaomoji message skips its row without aborting the walk.
jq -cs --argjson s "$START_IDX" '
  .[$s:]
  | .[]
  | select(.type == "event_msg" and (.payload.type // "") == "agent_message")
  | (.payload.message // "")
' "$ROLLOUT" 2>/dev/null | while IFS= read -r line; do
  [ -z "$line" ] && continue
  ASSISTANT_TEXT=$(printf '%s' "$line" | jq -r '.')
  ${KAOMOJI_VALIDATE}
  ${JOURNAL_WRITE}
done

exit 0
